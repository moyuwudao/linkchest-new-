{
  "version": "2.4",
  "description": "LinkChest 规则智能加载索引 - 根据任务类型动态加载相关规则",
  "rules": {
    "core": {
      "priority": "always",
      "files": [
        "SOUL.md",
        "USER.md",
        "INTERACTION.md"
      ],
      "description": "核心身份和交互规则，始终加载"
    },
    "safety": {
      "priority": "always",
      "files": [
        "RED_LINES.md",
        "HIGH_RISK.md"
      ],
      "description": "安全红线（Zero Tolerance）和高风险操作，始终加载"
    },
    "security": {
      "priority": "task",
      "files": [
        "CAUTION_ZONE.md"
      ],
      "description": "警告区域（应急响应、Web安全），安全相关任务时加载",
      "triggers": [
        "安全",
        "CSP",
        "XSS",
        "应急响应",
        "安全头"
      ]
    },
    "project": {
      "priority": "context",
      "files": [
        "PROJECT_SENSE.md"
      ],
      "description": "项目感知，需要项目上下文时加载",
      "triggers": [
        "项目结构",
        "技术栈",
        "快速入门"
      ]
    },
    "workflow": {
      "priority": "context",
      "files": [
        "common/DEVELOPMENT_WORKFLOW.md"
      ],
      "description": "开发工作流，首次访问项目时加载",
      "triggers": [
        "开发流程",
        "工作流",
        "需求分析",
        "代码提交"
      ]
    },
    "coding": {
      "priority": "task",
      "files": [
        "CODE_STYLE.md"
      ],
      "description": "代码风格规范，编写代码时加载",
      "triggers": [
        "编写代码",
        "代码风格",
        "函数定义",
        "类定义",
        "组件开发",
        "React",
        "TypeScript"
      ]
    },
    "testing": {
      "priority": "task",
      "files": [
        "TESTING.md"
      ],
      "description": "测试规范，编写测试时加载",
      "triggers": [
        "测试",
        "单元测试",
        "集成测试",
        "E2E",
        "jest",
        "playwright",
        "TDD"
      ]
    },
    "review": {
      "priority": "task",
      "files": [
        "common/CODE_REVIEW.md"
      ],
      "description": "代码审查标准，审查代码时加载",
      "triggers": [
        "代码审查",
        "PR",
        "pull request",
        "审查清单",
        "代码质量"
      ]
    },
    "quality": {
      "priority": "task",
      "files": [
        "LINT.md"
      ],
      "description": "代码质量检查，运行 lint/typecheck 时加载",
      "triggers": [
        "lint",
        "typecheck",
        "代码检查",
        "ESLint",
        "TypeScript",
        "类型错误"
      ]
    },
    "git": {
      "priority": "task",
      "files": [
        "GIT_WORKFLOW.md"
      ],
      "description": "Git 工作流，Git 操作时加载",
      "triggers": [
        "git",
        "commit",
        "分支",
        "PR",
        "pull request",
        "merge",
        "版本发布"
      ]
    },
    "build": {
      "priority": "task",
      "files": [
        "BUILD.md",
        "BUILD_RED_LINES.md"
      ],
      "description": "构建流程和构建红线，构建相关操作时加载（含APK构建详细流程）",
      "triggers": [
        "构建",
        "build",
        "APK",
        "打包",
        "Android",
        "iOS",
        "Chrome 扩展",
        "WSL",
        "gradle",
        "expo"
      ]
    },
    "deployment": {
      "priority": "task",
      "files": [
        "DEPLOYMENT.md"
      ],
      "description": "服务器部署，部署/推送操作时加载",
      "triggers": [
        "部署",
        "deploy",
        "上线",
        "发布",
        "ssh",
        "pm2",
        "服务器",
        "scp",
        "prisma db push",
        "migrate"
      ]
    },
    "hooks": {
      "priority": "task",
      "files": [
        "common/HOOKS.md"
      ],
      "description": "Hooks 系统，配置自动化工作流时加载",
      "triggers": [
        "hooks",
        "自动化",
        "PreToolUse",
        "PostToolUse"
      ]
    },
    "agents": {
      "priority": "task",
      "files": [
        "common/AGENTS.md"
      ],
      "description": "Agents 使用指南，调用工具时加载",
      "triggers": [
        "agent",
        "工具",
        "代码审查",
        "安全审查",
        "TDD",
        "性能优化"
      ]
    },
    "performance": {
      "priority": "task",
      "files": [
        "common/PERFORMANCE.md"
      ],
      "description": "性能优化策略，性能问题排查时加载",
      "triggers": [
        "性能",
        "优化",
        "响应时间",
        "缓存",
        "数据库查询"
      ]
    },
    "market-ops": {
      "priority": "task",
      "files": [
        "MARKET-OPS.md"
      ],
      "description": "国内外分运营配置方案，涉及支付/登录/合规时加载",
      "triggers": [
        "国内",
        "海外",
        "china",
        "global",
        "市场",
        "MARKET",
        "支付",
        "payment",
        "PayPal",
        "微信支付",
        "支付宝",
        "Google Pay",
        "Apple IAP",
        "登录",
        "auth",
        "OAuth",
        "微信登录",
        "Apple Sign In",
        "Google OAuth",
        "合规",
        "审核",
        "内容审核",
        "contentModeration",
        "Provider",
        "市场守卫",
        "marketGuard"
      ]
    },
    "index": {
      "priority": "context",
      "files": [
        "INDEX.md"
      ],
      "description": "规则体系总览，首次访问项目时加载",
      "triggers": [
        "规则总览",
        "快速查找",
        "规则结构"
      ]
    },
    "ecc-skills": {
      "files": ["ECC_SKILLS.md"],
      "priority": "task",
      "triggers": ["ECC Skill", "backend-patterns", "database-migrations", "security-review", "frontend-patterns", "git-workflow", "docker-patterns", "deployment-patterns"]
    }
  },
  "agents": {
    "core": [
      {
        "name": "planner",
        "purpose": "复杂功能规划",
        "triggers": ["复杂功能", "新功能开发", "大型任务"],
        "priority": "high"
      },
      {
        "name": "tdd-guide",
        "purpose": "TDD 流程指导",
        "triggers": ["测试", "TDD", "新功能"],
        "priority": "high"
      },
      {
        "name": "code-reviewer",
        "purpose": "代码审查",
        "triggers": ["代码审查", "PR", "代码质量"],
        "priority": "high"
      },
      {
        "name": "security-reviewer",
        "purpose": "安全分析",
        "triggers": ["安全", "认证", "支付", "用户数据"],
        "priority": "high"
      },
      {
        "name": "build-error-resolver",
        "purpose": "构建错误修复",
        "triggers": ["构建失败", "编译错误", "build error"],
        "priority": "medium"
      },
      {
        "name": "performance-optimizer",
        "purpose": "性能优化",
        "triggers": ["性能", "优化", "慢查询", "卡顿", "内存问题"],
        "priority": "medium"
      },
      {
        "name": "refactor-cleaner",
        "purpose": "死代码清理",
        "triggers": ["重构", "清理", "技术债务"],
        "priority": "low"
      }
    ]
  },
  "commands": {
    "core": [
      {
        "name": "/plan",
        "purpose": "功能规划",
        "agent": "planner"
      },
      {
        "name": "/tdd",
        "purpose": "TDD 流程",
        "agent": "tdd-guide"
      },
      {
        "name": "/review",
        "purpose": "代码审查",
        "agent": "code-reviewer"
      },
      {
        "name": "/security",
        "purpose": "安全审查",
        "agent": "security-reviewer"
      },
      {
        "name": "/build-fix",
        "purpose": "构建错误修复",
        "agent": "build-error-resolver"
      },
      {
        "name": "/optimize",
        "purpose": "性能优化",
        "agent": "performance-optimizer"
      },
      {
        "name": "/clean",
        "purpose": "死代码清理",
        "agent": "refactor-cleaner"
      }
    ]
  },
  "skills": {
    "deploy-linkchest": {
      "description": "部署自动化引导",
      "triggers": ["部署", "deploy", "上线", "发布", "ssh ubuntu@", "pm2 restart"],
      "bound_rules": ["HIGH_RISK.md", "DEPLOYMENT.md", "BUILD_RED_LINES.md", "ECC_SKILLS.md"]
    },
    "build-error-diagnose": {
      "description": "构建错误自动诊断",
      "triggers": ["构建失败", "编译错误", "build error", "gradle", "MODULE_NOT_FOUND"],
      "bound_rules": ["BUILD_RED_LINES.md", "BUILD.md", "ECC_SKILLS.md"]
    },
    "check-servers": {
      "description": "服务器健康检查",
      "triggers": ["检查服务器", "服务器状态", "健康检查", "服务是否正常"],
      "bound_rules": ["HIGH_RISK.md", "ECC_SKILLS.md"]
    },
    "rule-validator": {
      "description": "规则文件验证",
      "triggers": ["验证规则", "创建规则", "检查规则"],
      "bound_rules": ["INDEX.md"]
    }
  },
  "mcp": {
    "github": {
      "status": "connected",
      "primary_uses": ["PR管理", "Issue追踪", "代码搜索", "部署前commit检查"],
      "integrated_skills": ["deploy-linkchest"]
    },
    "playwright": {
      "status": "connected",
      "primary_uses": ["部署后页面验证", "E2E测试", "WEB渲染检查"],
      "integrated_skills": ["deploy-linkchest", "check-servers"]
    }
  }
}