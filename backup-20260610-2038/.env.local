# API地址 - 使用相对路径走 Next.js rewrite 代理，避免跨域 CORS 问题
NEXT_PUBLIC_API_URL=/api

# 市场配置: global (海外) | china (国内)
# 决定启用哪些支付/登录渠道和功能
NEXT_PUBLIC_MARKET=global

# Google OAuth Client ID（用于前端 GIS 初始化）
NEXT_PUBLIC_GOOGLE_CLIENT_ID=320062761256-77p8ie053nh2p8e8h2kv92gi53h56knu.apps.googleusercontent.com

# PayPal Client ID（前端 SDK 用）
# 在 https://developer.paypal.com/dashboard/applications 获取
# Sandbox ID 以 sb- 开头，Live ID 以真实值开头
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
