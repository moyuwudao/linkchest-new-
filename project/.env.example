# ============================================================
# LinkChest 环境配置示例
# 复制为 .env 后按需修改，请勿提交真实密钥到 Git
# ============================================================

# ========== 核心配置（必填） ==========

# 数据库配置 (PostgreSQL)
# 本地开发: docker compose up -d postgres
DATABASE_URL="postgresql://linkchest:your_db_password@localhost:5432/linkchest?schema=public"

# JWT 配置（必须设置，服务启动时会检查）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="dev-jwt-secret-change-me"
JWT_EXPIRES_IN="7d"

# 环境标识
NODE_ENV=development

# 市场标识: global（海外）| china（国内）
# 决定启用哪些支付/登录渠道、合规功能、定价货币等
MARKET=global

# ========== 服务端口 ==========

# API 服务端口
PORT=3001

# ========== URL 配置 ==========

# 分享链接基础 URL（后端生成分享短链时使用）
SHARE_BASE_URL="http://localhost:3001"

# Web 前端基础 URL（浏览器访问 /s/:id 时重定向到此地址）
WEB_BASE_URL="http://localhost:3001"

# 网页端 API 地址
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# CORS 允许的来源（逗号分隔，不设置则默认 localhost:3000 和 localhost:3001）
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# ========== Redis 缓存（可选但推荐） ==========

# Redis 连接串（用于用户缓存、分享缓存、验证码、限流等）
# 生产环境强烈建议配置，否则验证码等功能降级到内存
REDIS_URL="redis://localhost:6379"

# ========== 对象存储 COS（可选） ==========

# 腾讯云 COS / 轻量对象存储配置（封面上传、头像上传）
# 轻量对象存储完全兼容 COS SDK，只需填入桶名即可
# 注意：桶名具有全局唯一性
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION="ap-singapore"
# COS_DOMAIN=""  # 自定义 CDN 域名（可选）

# ========== 邮件推送 SES（可选） ==========

# 腾讯云 SES 邮件推送配置（国内外通用）
TENCENTCLOUD_SECRET_ID=""
TENCENTCLOUD_SECRET_KEY=""
SES_REGION="ap-guangzhou"

# 国内版邮箱配置（MARKET=china 时使用）
SES_FROM_EMAIL_CN="noreply@linkchest.cn"
SES_VERIFY_TEMPLATE_ID_CN="49526"

# 海外版邮箱配置（MARKET=global 时使用）
SES_FROM_EMAIL_GLOBAL="noreply@linkchest.net"
SES_VERIFY_TEMPLATE_ID_GLOBAL="175148"

# 通用配置（当对应市场配置不存在时回退使用）
SES_FROM_EMAIL="noreply@linkchest.net"
SES_VERIFY_TEMPLATE_ID="175148"

# ========== 第三方支付（可选） ==========

# PayPal 支付配置（海外 Web 端）
# 在 https://developer.paypal.com/dashboard/applications 获取
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# PayPal 订阅计划 ID（从 PayPal 后台 Subscriptions 获取）
# 格式: PAYPAL_PLAN_ID_{ENV}_{TIER}_{CYCLE}
# ENV: PROD(生产) | SANDBOX(沙盒)
# TIER: HEAVY | SUPER
# CYCLE: MONTHLY | QUARTERLY | YEARLY
# 示例值: P-XXXXXXXXXXXXXXXXXXXXXXXX
PAYPAL_PLAN_ID_SANDBOX_HEAVY_MONTHLY=""
PAYPAL_PLAN_ID_SANDBOX_HEAVY_QUARTERLY=""
PAYPAL_PLAN_ID_SANDBOX_HEAVY_YEARLY=""
PAYPAL_PLAN_ID_SANDBOX_SUPER_MONTHLY=""
PAYPAL_PLAN_ID_SANDBOX_SUPER_QUARTERLY=""
PAYPAL_PLAN_ID_SANDBOX_SUPER_YEARLY=""
PAYPAL_PLAN_ID_PROD_HEAVY_MONTHLY=""
PAYPAL_PLAN_ID_PROD_HEAVY_QUARTERLY=""
PAYPAL_PLAN_ID_PROD_HEAVY_YEARLY=""
PAYPAL_PLAN_ID_PROD_SUPER_MONTHLY=""
PAYPAL_PLAN_ID_PROD_SUPER_QUARTERLY=""
PAYPAL_PLAN_ID_PROD_SUPER_YEARLY=""

# Google Pay 配置（海外 Web 端）
# 在 https://pay.google.com/business/console 获取
GOOGLE_PAY_MERCHANT_ID=""
GOOGLE_PAY_MERCHANT_NAME="LinkChest"

# Apple In-App Purchase 配置（海外 iOS 端）
# 在 https://appstoreconnect.apple.com 获取
APPLE_SHARED_SECRET=""

# Google Play Billing 配置（海外 Android 端）
# 在 https://play.google.com/console 获取
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=""
GOOGLE_PLAY_PACKAGE_NAME="com.linkchest.app"

# 微信支付配置（国内）
# 在 https://pay.weixin.qq.com 申请商户号后获取
WECHAT_PAY_MCH_ID=""
WECHAT_PAY_APP_ID=""
WECHAT_PAY_API_V3_KEY=""
WECHAT_PAY_SERIAL_NO=""
WECHAT_PAY_PRIVATE_KEY=""

# 前端环境变量（apps/web/.env.production）
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
# NEXT_PUBLIC_GOOGLE_PAY_MERCHANT_ID=""

# ========== 社交登录（可选） ==========

# Google OAuth 登录（海外）
GOOGLE_CLIENT_ID=""

# Google OAuth Android 登录（海外移动端，用于 expo-auth-session）
# 在 https://console.cloud.google.com/apis/credentials 获取 Android 类型 OAuth 客户端 ID
GOOGLE_CLIENT_ID_ANDROID=""

# Apple Sign In（海外 iOS/macOS）
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# 微信登录（国内）
# 在 https://open.weixin.qq.com 申请
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# ===== 推送服务（国内=极光 / 海外=FCM）=====
# 通道选择由项目顶部的 MARKET 决定：
#   MARKET=china  → 极光（JPush）
#   MARKET=global → Firebase Cloud Messaging (FCM)

# 国内：极光（JPush）配置
# 从 https://www.jiguang.cn/ 后台获取
JPUSH_APPKEY=your_jpush_appkey_here
JPUSH_MASTER_SECRET=your_jpush_master_secret_here

# 海外：Firebase Cloud Messaging (FCM) 配置
# 从 Firebase Console → Project Settings → Cloud Messaging → "Server key" 获取
# 适用：MARKET=global
FCM_SERVER_KEY=your_fcm_server_key_here
# 可选：FCM 发送超时（毫秒，默认 5000）
FCM_TIMEOUT_MS=5000

# ===== 推送服务方案 B 占位（暂不启用）=====
# ⚠️ FCM Legacy HTTP API 将于 2024-06 弃用，长期应迁移到 HTTP v1
# 启用时填入：
#   1) 从 Firebase Console → Project Settings → Service Accounts → Generate new private key
#      下载 firebase-sa.json，放到海外服务器（不进 git）
#   2) npm install firebase-admin
#   3) 把下方占位的两行取消注释，并填入实际路径
# FIREBASE_SERVICE_ACCOUNT_PATH=/opt/linkchest/api/credentials/firebase-sa.json
# FCM_PROJECT_ID=linkchest-7e82f

# ========== 腾讯云内容安全（国内）==========

# 腾讯云 SecretId 和 SecretKey（用于内容审核 TMS / 邮件 SES / 短信等）
# ⚠️ 命名必须为 TENCENTCLOUD_* （与项目其他服务保持一致）
# 旧名称 TENCENT_SECRET_* 已废弃,会导致审核服务无法初始化
# 在 https://console.cloud.tencent.com/cms 开通
TENCENTCLOUD_SECRET_ID=""
TENCENTCLOUD_SECRET_KEY=""

# TMS 地域（仅国内市场生效）
# 推荐 ap-guangzhou（与 SES/COS-国内版一致,内网免费互通）
# 可选: ap-beijing | ap-shanghai | ap-guangzhou | ap-hongkong
TMS_REGION="ap-guangzhou"

# ========== 元数据抓取（可选） ==========

# Cloudflare Worker URL（元数据兜底，抓取困难站点时使用）
# CLOUDFLARE_WORKER_URL="https://linkchest-metadata.你的账号.workers.dev"

# 允许不安全的 HTTPS 证书（开发环境调试用）
# METADATA_ALLOW_INSECURE="true"

# ========== 管理员与运维（可选） ==========

# 管理员用户 ID 列表（逗号分隔）
ADMIN_USER_IDS=""

# 告警引擎开关（默认开启）
ALERTING_ENABLED="true"

# 告警扫描间隔（毫秒，默认 15 分钟 = 900000）
ALERT_SCAN_INTERVAL_MS="900000"

# 告警接收邮箱（逗号分隔）
ALERT_EMAILS=""

# 飞书 Webhook URL
FEISHU_WEBHOOK_URL=""

# 企业微信 Webhook URL
WECOM_WEBHOOK_URL=""

# ========== 日志（可选） ==========

# 日志级别（开发默认 debug，生产默认 info）
# LOG_LEVEL="info"

# PM2 日志目录（生产环境）
# PM2_LOG_DIR="/home/ubuntu/.pm2/logs"
# PM2_APP_NAME="linkchest-api"

# ========== 统一监控中心（国内服务器专用）==========

# 是否启用远程指标采集（国内服务器设为 true，海外服务器设为 false）
REMOTE_METRICS_ENABLED="false"

# 海外服务器指标拉取地址（国内服务器配置此项）
GLOBAL_SERVER_METRICS_URL="http://43.133.44.232:3001/api/admin/metrics"

# 海外服务器 API 认证 Token（可选，用于保护 metrics 端点）
GLOBAL_SERVER_API_TOKEN=""
