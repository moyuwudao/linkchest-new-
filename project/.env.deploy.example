# LinkChest 服务器部署配置
# 复制此文件为 .env.deploy 并填写实际值

# 服务器 IP 地址
DEPLOY_SERVER_IP=your-server-ip

# SSH 用户名（默认 ubuntu）
DEPLOY_SSH_USER=ubuntu

# SSH 密码（如果使用密钥登录，此项可留空）
DEPLOY_SSH_PASSWORD=your-ssh-password

# SSH 私钥路径（如果使用密码登录，此项可留空）
# Windows 路径示例: C:\Users\YourName\.ssh\id_rsa
# DEPLOY_SSH_KEY=C:\Users\YourName\.ssh\id_rsa
